# Anthropic API Key
ANTHROPIC_API_KEY=your-api-key-here

# Browser settings
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=100

# Zoho Creator API Credentials
# Get these from https://api-console.zoho.com (Self Client)
ZOHO_CLIENT_ID=your-client-id-here
ZOHO_CLIENT_SECRET=your-client-secret-here
ZOHO_REFRESH_TOKEN=your-refresh-token-here
ZOHO_OWNER_NAME=your-zoho-owner-name

# Zoho domain: accounts.zoho.com, accounts.zoho.in, accounts.zoho.eu, etc.
ZOHO_ACCOUNTS_DOMAIN=accounts.zoho.com
# Creator API domain: creator.zoho.com, creator.zoho.in, etc.
ZOHO_CREATOR_DOMAIN=creator.zoho.com
